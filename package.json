{
  "name": "@vowena/sdk",
  "version": "0.1.6",
  "publishConfig": {
    "access": "public"
  },
  "description": "TypeScript SDK for the Vowena recurring payment protocol on Stellar",
  "license": "Apache-2.0",
  "homepage": "https://docs.vowena.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/vowena/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/vowena/sdk/issues"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^15.0.1"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
